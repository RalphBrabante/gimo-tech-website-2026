NODE_ENV=production
# Hostinger provides PORT automatically. Use 3000 only for a VPS/manual setup.
PORT=3000
# Optional: only needed when the API is called from a different domain.
# CLIENT_ORIGIN=https://www.example.com

# Hostinger MySQL/MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u285537938_gimo_2026
DB_USERNAME=u285537938_gimo_2026
# Set this securely in Hostinger hPanel. Never commit the real password.
DB_PASSWORD=
DB_SSL=false
# Hostinger managed hosting does not provide manual npm commands, so migrations
# are applied during application startup. Set false only when managed separately.
DB_RUN_MIGRATIONS=true

# Use a random value of at least 32 characters. Changing it signs out all users.
AUTH_SECRET=replace-with-a-long-random-secret
# Public origin used to build password-reset links. Do not include a trailing slash.
PUBLIC_BASE_URL=https://gimosupplies.com

# Hostinger Agentic Mail token. Create a selected-mailbox token scoped only to
# sales@gimosupplies.com under hPanel > Emails > gimosupplies.com > Agentic mail.
HOSTINGER_MAIL_API_TOKEN=
HOSTINGER_MAILBOX_ADDRESS=sales@gimosupplies.com
